# Env (never commit real secrets — only `.env.example` is tracked)
.env
.env.*
!.env.example
*.env.backup

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/

# Node
node_modules/
.pnpm-store/
.turbo/
.next/
.vite/
.cache/

# Editors
.vscode/
.idea/
.DS_Store

# Logs / local data
*.log
logs/
.local/
.observer-state.json

# Docker volumes (if mounted locally)
.data/

# Secrets / tooling artifacts never committed individually
**/secrets.*
coverage.xml
coverage/
htmlcov/
*.pem
