# =============================================================================
# Mycelium environment variables
# =============================================================================
# Copy this to .env and adjust. Every service reads from this file.
# DEV_MODE=true is the default; every service must check it on startup and log:
#   "Running in DEV_MODE — auth disabled"
# =============================================================================

# ---- Global ----
DEV_MODE=true
LOG_LEVEL=INFO
ENVIRONMENT=local

# ---- Auth (DEV_MODE bypasses these) ----
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
DEV_USER_ID=dev-user-1
DEV_USER_EMAIL=dev@mycelium.local

# ---- Postgres (system of record) ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=mycelium
POSTGRES_USER=mycelium
POSTGRES_PASSWORD=mycelium
POSTGRES_DSN=postgresql://mycelium:mycelium@postgres:5432/mycelium

# ---- Neo4j (owned by services/knowledge ONLY) ----
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mycelium-neo4j

# ---- Redis Streams (transport only) ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
REDIS_CONSUMER_GROUP=mycelium

# ---- Service URLs (intra-service HTTP queries) ----
API_URL=http://api:8000
KNOWLEDGE_URL=http://knowledge:8001
AGENT_RUNTIME_URL=http://agent-runtime:8002
INTEGRATIONS_URL=http://integrations:8003
PROCESS_INTEL_URL=http://process-intel:8004
LEARNING_URL=http://learning:8005
SECURITY_URL=http://security:8006

# ---- Frontend ----
VITE_API_URL=http://localhost:8000

# ---- Integrations (Composio recommended) ----
COMPOSIO_API_KEY=
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# ---- Sync schedule (seconds) ----
INTEGRATIONS_SYNC_INTERVAL=300

# ---- Observer (runs LOCALLY, not in Docker) ----
# Point at the API on the host
OBSERVER_API_URL=http://localhost:8000
OBSERVER_WATCH_DIRS=
OBSERVER_USER_ID=dev-user-1

# ---- Agent runtime ----
OPENCLAW_API_KEY=
CLAWORC_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Knowledge service ----
GRAPHITI_LLM_PROVIDER=openai
GRAPHITI_LLM_MODEL=gpt-4o-mini

# ---- Observability ----
PROMETHEUS_PORT=9090
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=mycelium-dev
LANGSMITH_TRACING=false

# ---- Security / classification ----
CLASSIFICATION_RETRY_LIMIT=3
SECURITY_ENFORCEMENT_ENABLED=false
