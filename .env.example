# =============================================================================
# Mycelium environment variables (safe template — copy to `.env` and fill blanks)
# =============================================================================
# SECURITY
# - Never commit `.env`. Git ignores `.env` and `.env.*` while keeping this
#   file tracked (`!.env.example`).
# - Frontend never sees secrets; only NEXT_PUBLIC_* vars reach the browser.
# =============================================================================

# ---- Mycelium MVP (apps/api/app + apps/web) ---------------------------------
# Postgres DSN used by SQLAlchemy. psycopg3 driver is added automatically if
# you provide the bare `postgresql://` form.
POSTGRES_DSN=postgresql+psycopg://mycelium:mycelium@postgres:5432/mycelium

# OpenAI — required for real GPT-4o calls. If unset, agents fall back to
# deterministic mock responses so the local demo still works end to end.
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.2

# Jira — optional. Falls back to seeded fake tasks when unset.
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# GitHub — optional. Falls back to seeded fake repo files when unset.
# For autonomous execution, generate a Personal Access Token on the BOT
# account (NOT your personal account) with scope: repo (for public repos:
# public_repo). Add the bot account as a collaborator on the target repo.
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_DEFAULT_BASE_BRANCH=main
# Optional: comma-separated list of path globs the bot is allowed to write.
# Example: docs/**,scripts/*.sh  — empty = no path restriction (but hard
# blocks like `.env`, `secrets/`, `.github/workflows/` still apply).
GITHUB_ALLOWED_WRITE_PATHS=

# ---- Mycelium bot identity / autonomous execution --------------------------
# When a Jira task's assignee matches this value (displayName, email, or
# accountId), the orchestrator treats the assignment itself as the human
# approval and runs the plan end-to-end (branch -> file edits -> PR ->
# Jira comment). Leave empty to keep draft-only behaviour.
MYCELIUM_BOT_JIRA_USER=
MYCELIUM_BOT_NAME=Mycelium Bot
# Kill-switch. Set to false to force draft-only mode even when a bot-assigned
# task is detected.
MYCELIUM_AUTO_EXECUTE=true
# Safety: even with a GitHub token set, writes stay in dry-run mode unless
# this is explicitly true. Flip to true only once you've verified the bot
# account, target repo, and allow-list.
MYCELIUM_ALLOW_REAL_GITHUB=false

# ---- Jira watcher ----------------------------------------------------------
# Poll Jira on a timer for newly-assigned bot tasks. When off, you can still
# trigger a one-shot poll via POST /agents/watch from the UI.
JIRA_WATCHER_ENABLED=false
JIRA_WATCHER_INTERVAL_SECONDS=60
# Optional JQL appended with AND to narrow the watcher. Example:
#   status in ('To Do','In Progress') AND updated >= -7d
JIRA_WATCHER_EXTRA_JQL=

# Web (Next.js)
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
FRONTEND_ORIGIN=http://localhost:3000

# Demo
ENABLE_DEMO_SEED=true

# =============================================================================
# Legacy multi-service stack (services/* + apps/api/src). Optional — only used
# when running `docker compose -f docker-compose.legacy.yml up`.
# =============================================================================

# ---- Global ----
DEV_MODE=true
LOG_LEVEL=INFO
ENVIRONMENT=local

# ---- Auth (DEV_MODE bypasses these) ----
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
DEV_USER_ID=dev-user-1
DEV_USER_EMAIL=dev@mycelium.local

# ---- Postgres (system of record) ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=mycelium
POSTGRES_USER=mycelium
POSTGRES_PASSWORD=mycelium
POSTGRES_DSN=postgresql://mycelium:mycelium@postgres:5432/mycelium

# ---- Neo4j (owned by services/knowledge ONLY) ----
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mycelium-neo4j

# ---- Redis Streams (transport only) ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
REDIS_CONSUMER_GROUP=mycelium

# ---- Service URLs (intra-service HTTP queries) ----
API_URL=http://api:8000
KNOWLEDGE_URL=http://knowledge:8001
AGENT_RUNTIME_URL=http://agent-runtime:8002
INTEGRATIONS_URL=http://integrations:8003
PROCESS_INTEL_URL=http://process-intel:8004
LEARNING_URL=http://learning:8005
SECURITY_URL=http://security:8006

# ---- Frontend ----
VITE_API_URL=http://localhost:8000

# ---- Integrations (Composio recommended) ----
COMPOSIO_API_KEY=
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# ---- Sync schedule (seconds) ----
INTEGRATIONS_SYNC_INTERVAL=300

# ---- Observer (runs LOCALLY, not in Docker) ----
# Point at the API on the host
OBSERVER_API_URL=http://localhost:8000
OBSERVER_WATCH_DIRS=
OBSERVER_USER_ID=dev-user-1

# ---- Agent runtime ----
OPENCLAW_API_KEY=
CLAWORC_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Knowledge service ----
GRAPHITI_LLM_PROVIDER=openai
GRAPHITI_LLM_MODEL=gpt-4o-mini

# ---- Embeddings (used by services/knowledge + services/agent-runtime) ----
# hash   = deterministic, dependency-free, dev/CI default (NOT for real semantic search)
# openai = text-embedding-3-small (1536 dim) — requires OPENAI_API_KEY above
EMBEDDING_PROVIDER=hash
EMBEDDING_POLL_SECONDS=30
EMBEDDING_BATCH_SIZE=50
EMBEDDING_TYPE_DENYLIST=health,heartbeat,integration_sync.

# ---- Agent memory ----
MEMORY_BUFFER_SIZE=20
MEMORY_TTL_SECONDS=3600
MEMORY_LRU_CAP=100
LONGTERM_MEMORY_TOP_K=5
LONGTERM_MEMORY_SCOPE=agent_user  # agent_user | agent_only | user_only | global

# ---- Observability ----
PROMETHEUS_PORT=9090
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=mycelium-dev
LANGSMITH_TRACING=false

# ---- Security / classification ----
CLASSIFICATION_RETRY_LIMIT=3
SECURITY_ENFORCEMENT_ENABLED=false
